server {
    listen ${PORT};
    listen [::]:${PORT} ipv6only=on;
    root /usr/share/nginx/html;
    index index.html;

    # HTML shell — always revalidate so deploys take effect immediately
    location = /index.html {
        add_header Cache-Control "no-cache";
        try_files $uri =404;
    }

    # Service worker and manifest — always revalidate
    location = /sw.js {
        add_header Cache-Control "no-cache";
        try_files $uri =404;
    }
    location = /manifest.json {
        add_header Cache-Control "no-cache";
        try_files $uri =404;
    }

    # Hashed assets — cache forever (content-addressed by Vite)
    location /assets/ {
        add_header Cache-Control "public, max-age=31536000, immutable";
        try_files $uri =404;
    }

    # SPA fallback for client-side routes
    location / {
        try_files $uri $uri/ /index.html;
    }
}
